{
  "manifest_schema_version": 3,
  "app_id": "notes",
  "version": "3.1.0",
  "name": "Notes",
  "description": "Personal notes with folders, tags, full-text search, and trash management for your workspace.",
  "icon": "icon.svg",
  "actions_explicit": true,
  "capabilities": [
    "notes:read",
    "notes:write"
  ],
  "tools": [
    {
      "name": "tool_notes_chat",
      "description": "Personal notes assistant — create, read, update, delete, search, organize notes with folders and tags, move notes, manage trash",
      "scopes": [],
      "parameters": {
        "message": {
          "type": "string",
          "required": false
        },
        "kwargs": {
          "type": "string",
          "required": true
        }
      }
    },
    {
      "name": "skeleton_refresh_notes",
      "description": "Note statistics: total count, pinned, trash, recent titles.",
      "scopes": [],
      "parameters": {}
    },
    {
      "name": "list_notes",
      "description": "List notes (paginated). Returns up to `limit` rows per call (max 200). If `has_more` is true, call again with `offset=offset+limit` to fetch the next page.",
      "action_type": "read",
      "chain_callable": false,
      "effects": [],
      "params_schema": {
        "description": "List notes with optional filters.",
        "properties": {
          "limit": {
            "default": 50,
            "description": "Max notes per page (1-200). Use offset to paginate.",
            "maximum": 200,
            "minimum": 1,
            "title": "Limit",
            "type": "integer"
          },
          "offset": {
            "default": 0,
            "description": "Pagination offset",
            "minimum": 0,
            "title": "Offset",
            "type": "integer"
          },
          "folder_id": {
            "default": "",
            "description": "Filter by folder UUID (not folder name).",
            "title": "Folder Id",
            "type": "string"
          },
          "search": {
            "default": "",
            "description": "Filter by text",
            "title": "Search",
            "type": "string"
          },
          "tags": {
            "description": "Filter by tag names (AND-match: a note must have all listed tags).",
            "items": {
              "type": "string"
            },
            "title": "Tags",
            "type": "array"
          }
        },
        "title": "ListNotesParams",
        "type": "object"
      },
      "return_schema": {},
      "event": "",
      "scopes": [],
      "owner_chat_tool": "tool_notes_chat"
    },
    {
      "name": "get_note",
      "description": "Get full content of a note by ID.",
      "action_type": "read",
      "chain_callable": false,
      "effects": [],
      "params_schema": {
        "description": "Target a specific note.",
        "properties": {
          "note_id": {
            "default": "",
            "description": "Note UUID. Required.",
            "title": "Note Id",
            "type": "string"
          }
        },
        "title": "NoteIdParams",
        "type": "object"
      },
      "return_schema": {},
      "event": "",
      "scopes": [],
      "owner_chat_tool": "tool_notes_chat"
    },
    {
      "name": "create_note",
      "description": "Create a new note with title, content, tags, and optional folder.",
      "action_type": "write",
      "chain_callable": true,
      "effects": [
        "create:note"
      ],
      "params_schema": {
        "description": "Create a new note.\n\n`title` and `content_text` both have safe defaults — handler-side\nnormalization decides what to do with empty values rather than\nPydantic rejecting the call. LLMs occasionally pass `content`,\n`body`, `text` instead of `content_text` — accepted via aliases.",
        "properties": {
          "title": {
            "default": "",
            "description": "Note title. Field name is 'title' — never the folder name.",
            "title": "Title",
            "type": "string"
          },
          "content_text": {
            "default": "",
            "description": "Note body text. Field name in tool calls is 'content_text' — never 'content', 'body', or 'text', though those are accepted as aliases.",
            "title": "Content Text",
            "type": "string"
          },
          "tags": {
            "description": "Tags list",
            "items": {
              "type": "string"
            },
            "title": "Tags",
            "type": "array"
          },
          "folder_id": {
            "default": "",
            "description": "Folder UUID (NOT folder name; resolve via resolve_folder first).",
            "title": "Folder Id",
            "type": "string"
          }
        },
        "title": "CreateNoteParams",
        "type": "object"
      },
      "return_schema": {},
      "event": "created",
      "scopes": [],
      "owner_chat_tool": "tool_notes_chat"
    },
    {
      "name": "update_note",
      "description": "Update note title, content, tags, or pin status.",
      "action_type": "write",
      "chain_callable": true,
      "effects": [
        "update:note"
      ],
      "params_schema": {
        "description": "Update an existing note.",
        "properties": {
          "note_id": {
            "default": "",
            "description": "Note UUID. Required.",
            "title": "Note Id",
            "type": "string"
          },
          "title": {
            "default": "",
            "description": "New title (omit to keep).",
            "title": "Title",
            "type": "string"
          },
          "content_text": {
            "default": "",
            "description": "New content (omit to keep).",
            "title": "Content Text",
            "type": "string"
          },
          "tags": {
            "anyOf": [
              {
                "items": {
                  "type": "string"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "description": "New tags (omit to keep).",
            "title": "Tags"
          },
          "is_pinned": {
            "anyOf": [
              {
                "type": "boolean"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "description": "Pin status (omit to keep).",
            "title": "Is Pinned"
          }
        },
        "title": "UpdateNoteParams",
        "type": "object"
      },
      "return_schema": {},
      "event": "updated",
      "scopes": [],
      "owner_chat_tool": "tool_notes_chat"
    },
    {
      "name": "move_note",
      "description": "Move note to a folder, or root with empty folder_id.",
      "action_type": "write",
      "chain_callable": true,
      "effects": [
        "update:note"
      ],
      "params_schema": {
        "description": "Move note to a folder.",
        "properties": {
          "note_id": {
            "default": "",
            "description": "Note UUID to move. Required.",
            "title": "Note Id",
            "type": "string"
          },
          "folder_id": {
            "default": "",
            "description": "Target folder UUID. Empty string moves to root.",
            "title": "Folder Id",
            "type": "string"
          }
        },
        "title": "MoveNoteParams",
        "type": "object"
      },
      "return_schema": {},
      "event": "moved",
      "scopes": [],
      "owner_chat_tool": "tool_notes_chat"
    },
    {
      "name": "delete_note",
      "description": "Delete a note (moves to trash).",
      "action_type": "destructive",
      "chain_callable": true,
      "effects": [
        "trash:note"
      ],
      "params_schema": {
        "description": "Target a specific note.",
        "properties": {
          "note_id": {
            "default": "",
            "description": "Note UUID. Required.",
            "title": "Note Id",
            "type": "string"
          }
        },
        "title": "NoteIdParams",
        "type": "object"
      },
      "return_schema": {},
      "event": "deleted",
      "scopes": [],
      "owner_chat_tool": "tool_notes_chat"
    },
    {
      "name": "permanent_delete_note",
      "description": "Permanently delete a note. Cannot be undone.",
      "action_type": "destructive",
      "chain_callable": true,
      "effects": [
        "delete:note"
      ],
      "params_schema": {
        "description": "Target a specific note.",
        "properties": {
          "note_id": {
            "default": "",
            "description": "Note UUID. Required.",
            "title": "Note Id",
            "type": "string"
          }
        },
        "title": "NoteIdParams",
        "type": "object"
      },
      "return_schema": {},
      "event": "permanently_deleted",
      "scopes": [],
      "owner_chat_tool": "tool_notes_chat"
    },
    {
      "name": "delete_notes_from_folder",
      "description": "Delete ALL notes in a folder (bulk). By default moves them to trash; pass permanent=true to permanently delete instead. Use resolve_folder first if you only have the folder name, not its UUID.",
      "action_type": "destructive",
      "chain_callable": true,
      "effects": [
        "trash:note",
        "delete:note"
      ],
      "params_schema": {
        "description": "Bulk-delete all notes in a folder.",
        "properties": {
          "folder_id": {
            "default": "",
            "description": "Folder UUID. Required — use resolve_folder first if you only have the name.",
            "title": "Folder Id",
            "type": "string"
          },
          "permanent": {
            "default": false,
            "description": "If true, permanently delete all notes (cannot be undone). If false (default), move to trash.",
            "title": "Permanent",
            "type": "boolean"
          }
        },
        "title": "DeleteNotesFromFolderParams",
        "type": "object"
      },
      "return_schema": {},
      "event": "bulk_deleted",
      "scopes": [],
      "owner_chat_tool": "tool_notes_chat"
    },
    {
      "name": "search_notes",
      "description": "Full-text search across all notes (paginated). Returns up to `limit` results per call (max 50). If `has_more` is true, call again with `offset=offset+limit` to fetch the next page. Do NOT claim to have searched all notes until `has_more` is false.",
      "action_type": "read",
      "chain_callable": false,
      "effects": [],
      "params_schema": {
        "description": "Full-text search.",
        "properties": {
          "query": {
            "default": "",
            "description": "Search query. Required (non-empty).",
            "title": "Query",
            "type": "string"
          },
          "limit": {
            "default": 20,
            "description": "Max results per page (1-50). Use offset to paginate.",
            "maximum": 50,
            "minimum": 1,
            "title": "Limit",
            "type": "integer"
          },
          "offset": {
            "default": 0,
            "description": "Pagination offset",
            "minimum": 0,
            "title": "Offset",
            "type": "integer"
          }
        },
        "title": "SearchNotesParams",
        "type": "object"
      },
      "return_schema": {},
      "event": "",
      "scopes": [],
      "owner_chat_tool": "tool_notes_chat"
    },
    {
      "name": "list_folders",
      "description": "List all note folders.",
      "action_type": "read",
      "chain_callable": false,
      "effects": [],
      "params_schema": {
        "description": "Empty params model for @chat.function handlers that take no business inputs (V17).",
        "properties": {},
        "title": "NoParams",
        "type": "object"
      },
      "return_schema": {},
      "event": "",
      "scopes": [],
      "owner_chat_tool": "tool_notes_chat"
    },
    {
      "name": "resolve_folder",
      "description": "Resolve a folder by name (case-insensitive). Returns the folder_id plus match_quality ('exact' | 'prefix' | 'contains' | 'none'). Use this INSTEAD of list_folders+manual-match when you only need one folder — it's a single call and gives a stable ID across chain steps.",
      "action_type": "read",
      "chain_callable": false,
      "effects": [],
      "params_schema": {
        "properties": {
          "name": {
            "default": "",
            "description": "Folder name to resolve (case-insensitive, whitespace-trimmed). Required.",
            "title": "Name",
            "type": "string"
          }
        },
        "title": "ResolveFolderParams",
        "type": "object"
      },
      "return_schema": {},
      "event": "",
      "scopes": [],
      "owner_chat_tool": "tool_notes_chat"
    },
    {
      "name": "create_folder",
      "description": "Create a new folder.",
      "action_type": "write",
      "chain_callable": true,
      "effects": [
        "create:folder"
      ],
      "params_schema": {
        "properties": {
          "name": {
            "default": "",
            "description": "Folder name. Required.",
            "title": "Name",
            "type": "string"
          }
        },
        "title": "CreateFolderParams",
        "type": "object"
      },
      "return_schema": {},
      "event": "folder_created",
      "scopes": [],
      "owner_chat_tool": "tool_notes_chat"
    },
    {
      "name": "rename_folder",
      "description": "Rename an existing folder.",
      "action_type": "write",
      "chain_callable": true,
      "effects": [
        "update:folder"
      ],
      "params_schema": {
        "properties": {
          "folder_id": {
            "default": "",
            "description": "Folder UUID to rename. Required.",
            "title": "Folder Id",
            "type": "string"
          },
          "name": {
            "default": "",
            "description": "New folder name. Required.",
            "title": "Name",
            "type": "string"
          }
        },
        "title": "RenameFolderParams",
        "type": "object"
      },
      "return_schema": {},
      "event": "folder_renamed",
      "scopes": [],
      "owner_chat_tool": "tool_notes_chat"
    },
    {
      "name": "delete_folder",
      "description": "Delete a folder (notes move to root).",
      "action_type": "destructive",
      "chain_callable": true,
      "effects": [
        "delete:folder"
      ],
      "params_schema": {
        "properties": {
          "folder_id": {
            "default": "",
            "description": "Folder UUID. Required.",
            "title": "Folder Id",
            "type": "string"
          }
        },
        "title": "FolderIdParams",
        "type": "object"
      },
      "return_schema": {},
      "event": "folder_deleted",
      "scopes": [],
      "owner_chat_tool": "tool_notes_chat"
    },
    {
      "name": "delete_folder_with_contents",
      "description": "Delete a folder AND all notes inside it. By default moves notes to trash then deletes the folder; pass permanent=true to permanently delete notes instead. Use this when the user wants to remove a folder with everything in it. Use resolve_folder first if you only have the folder name.",
      "action_type": "destructive",
      "chain_callable": true,
      "effects": [
        "trash:note",
        "delete:note",
        "delete:folder"
      ],
      "params_schema": {
        "properties": {
          "folder_id": {
            "default": "",
            "description": "Folder UUID. Required — use resolve_folder first if you only have the name.",
            "title": "Folder Id",
            "type": "string"
          },
          "permanent": {
            "default": false,
            "description": "If true, permanently delete all notes (cannot be undone). If false (default), move notes to trash first, then delete folder.",
            "title": "Permanent",
            "type": "boolean"
          }
        },
        "title": "DeleteFolderWithContentsParams",
        "type": "object"
      },
      "return_schema": {},
      "event": "folder_with_contents_deleted",
      "scopes": [],
      "owner_chat_tool": "tool_notes_chat"
    },
    {
      "name": "list_trash",
      "description": "List all notes in trash.",
      "action_type": "read",
      "chain_callable": false,
      "effects": [],
      "params_schema": {
        "description": "Empty params model for @chat.function handlers that take no business inputs (V17).",
        "properties": {},
        "title": "NoParams",
        "type": "object"
      },
      "return_schema": {},
      "event": "",
      "scopes": [],
      "owner_chat_tool": "tool_notes_chat"
    },
    {
      "name": "restore_note",
      "description": "Restore a note from trash.",
      "action_type": "write",
      "chain_callable": true,
      "effects": [
        "update:note"
      ],
      "params_schema": {
        "properties": {
          "note_id": {
            "default": "",
            "description": "Note UUID to restore. Required.",
            "title": "Note Id",
            "type": "string"
          }
        },
        "title": "RestoreNoteParams",
        "type": "object"
      },
      "return_schema": {},
      "event": "restored",
      "scopes": [],
      "owner_chat_tool": "tool_notes_chat"
    },
    {
      "name": "empty_trash",
      "description": "Permanently delete all trashed notes.",
      "action_type": "destructive",
      "chain_callable": true,
      "effects": [
        "delete:note"
      ],
      "params_schema": {
        "description": "Empty params model for @chat.function handlers that take no business inputs (V17).",
        "properties": {},
        "title": "NoParams",
        "type": "object"
      },
      "return_schema": {},
      "event": "emptied",
      "scopes": [],
      "owner_chat_tool": "tool_notes_chat"
    },
    {
      "name": "note_save",
      "description": "Save a note field from the editor panel (title, content, tags, folder, pin, archive).",
      "action_type": "write",
      "chain_callable": true,
      "effects": [
        "update:note"
      ],
      "params_schema": {
        "properties": {
          "note_id": {
            "default": "",
            "description": "Note UUID. Required.",
            "title": "Note Id",
            "type": "string"
          },
          "field": {
            "default": "",
            "description": "Field to save: title | content | tags | folder | archive | unarchive | pin",
            "title": "Field",
            "type": "string"
          },
          "title": {
            "default": "",
            "description": "New title (when field=title)",
            "title": "Title",
            "type": "string"
          },
          "content_text": {
            "default": "",
            "description": "HTML content (when field=content)",
            "title": "Content Text",
            "type": "string"
          },
          "tags": {
            "description": "Tag list (when field=tags)",
            "items": {
              "type": "string"
            },
            "title": "Tags",
            "type": "array"
          },
          "folder_id": {
            "default": "",
            "description": "Folder UUID or empty string to remove (when field=folder)",
            "title": "Folder Id",
            "type": "string"
          }
        },
        "title": "NoteSaveParams",
        "type": "object"
      },
      "return_schema": {},
      "event": "updated",
      "scopes": [],
      "owner_chat_tool": "tool_notes_chat"
    },
    {
      "name": "upload_attachment",
      "description": "Upload a file attachment to a note.",
      "action_type": "write",
      "chain_callable": true,
      "effects": [
        "create:attachment"
      ],
      "params_schema": {
        "properties": {
          "note_id": {
            "default": "",
            "description": "Note UUID",
            "title": "Note Id",
            "type": "string"
          },
          "files": {
            "default": null,
            "description": "FileUpload payload (list[dict] with data_base64/name/content_type)",
            "title": "Files"
          }
        },
        "title": "AttachmentUploadParams",
        "type": "object"
      },
      "return_schema": {},
      "event": "attachment.uploaded",
      "scopes": [],
      "owner_chat_tool": "tool_notes_chat"
    },
    {
      "name": "delete_attachment",
      "description": "Delete a file attachment from a note.",
      "action_type": "write",
      "chain_callable": true,
      "effects": [
        "delete:attachment"
      ],
      "params_schema": {
        "properties": {
          "note_id": {
            "default": "",
            "description": "Note UUID",
            "title": "Note Id",
            "type": "string"
          },
          "att_id": {
            "default": "",
            "description": "Attachment UUID",
            "title": "Att Id",
            "type": "string"
          }
        },
        "title": "AttachmentDeleteParams",
        "type": "object"
      },
      "return_schema": {},
      "event": "attachment.deleted",
      "scopes": [],
      "owner_chat_tool": "tool_notes_chat"
    },
    {
      "name": "duplicate_note",
      "description": "Duplicate a note — copies title, content, folder, and tags into a new note.",
      "action_type": "write",
      "chain_callable": true,
      "effects": [
        "create:note"
      ],
      "params_schema": {
        "properties": {
          "note_id": {
            "default": "",
            "description": "Note UUID",
            "title": "Note Id",
            "type": "string"
          }
        },
        "title": "NoteIdParams",
        "type": "object"
      },
      "return_schema": {},
      "event": "notes.created",
      "scopes": [],
      "owner_chat_tool": "tool_notes_chat"
    },
    {
      "name": "export_markdown",
      "description": "Export a note as Markdown. Returns the converted content with a download button.",
      "action_type": "read",
      "chain_callable": false,
      "effects": [],
      "params_schema": {
        "properties": {
          "note_id": {
            "default": "",
            "description": "Note UUID",
            "title": "Note Id",
            "type": "string"
          }
        },
        "title": "NoteIdParams",
        "type": "object"
      },
      "return_schema": {},
      "event": "",
      "scopes": [],
      "owner_chat_tool": "tool_notes_chat"
    }
  ],
  "signals": [],
  "schedules": [],
  "required_scopes": [],
  "icon_size_bytes": 379,
  "events": {
    "subscribes": [],
    "emits": [
      {
        "type": "notes.folder_with_contents_deleted"
      },
      {
        "type": "notes.folder_deleted"
      },
      {
        "type": "notes.folder_renamed"
      },
      {
        "type": "notes.folder_created"
      },
      {
        "type": "notes.bulk_deleted"
      },
      {
        "type": "notes.emptied"
      },
      {
        "type": "notes.restored"
      },
      {
        "type": "notes.moved"
      },
      {
        "type": "notes.permanently_deleted"
      },
      {
        "type": "notes.deleted"
      },
      {
        "type": "notes.updated"
      },
      {
        "type": "notes.created"
      }
    ]
  },
  "lifecycle": {
    "on_install": true,
    "health_check": {
      "interval_sec": 60
    }
  },
  "lifecycle_hooks": {
    "on_install": {
      "signature": "(ctx) -> 'None'"
    }
  }
}